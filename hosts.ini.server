# 서버에서 사용할 인벤토리 파일
# SSH를 통해 자기 자신 및 동국대 서버를 점검
# SSH 키 경로: /opt/ansible-monitoring/.ssh/nimso2026.pem

[webservers]
nimbus-server ansible_host=127.0.0.1 ansible_connection=ssh ansible_port=22 ansible_user=root ansible_ssh_private_key_file=/opt/ansible-monitoring/.ssh/nimso2026.pem ansible_hostname_display=nimbus-navercloud
dongguk_server1 ansible_host=192.168.0.23 ansible_connection=ssh ansible_port=2222 ansible_user=root ansible_ssh_pass=0124 ansible_hostname_display=dongguk-server

[mariadb]
nimbus-server ansible_host=127.0.0.1 ansible_connection=ssh ansible_port=22 ansible_user=root ansible_ssh_private_key_file=/opt/ansible-monitoring/.ssh/nimso2026.pem ansible_hostname_display=nimbus-navercloud
dongguk_server1 ansible_host=192.168.0.23 ansible_connection=ssh ansible_port=2222 ansible_user=root ansible_ssh_pass=0124 ansible_hostname_display=dongguk-server

[postgresql]
nimbus-server ansible_host=127.0.0.1 ansible_connection=ssh ansible_port=22 ansible_user=root ansible_ssh_private_key_file=/opt/ansible-monitoring/.ssh/nimso2026.pem ansible_hostname_display=nimbus-navercloud
dongguk_server1 ansible_host=192.168.0.23 ansible_connection=ssh ansible_port=2222 ansible_user=root ansible_ssh_pass=0124 ansible_hostname_display=dongguk-server
