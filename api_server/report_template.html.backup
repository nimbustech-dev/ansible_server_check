<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DB 점검 결과 모니터링 대시보드</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            /* NeoGlass Dark */
            --bg: #0b1020;
            --panel: rgba(17, 25, 40, 0.62);
            --border: rgba(148, 163, 184, 0.18);
            --text: #e5e7eb;
            --muted: rgba(203, 213, 225, 0.72);
            --primary: #5eead4;
            --primary-2: #38bdf8;
            --success: #34d399;
            --warning: #fbbf24;
            --danger: #fb7185;
            --shadow: 0 20px 60px rgba(0, 0, 0, 0.55);
            --shadow-sm: 0 10px 30px rgba(0, 0, 0, 0.45);
            --radius: 16px;
            --table-head: rgba(15, 23, 42, 0.90);
            --glass-blur: 18px;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            background:
                radial-gradient(900px circle at 12% 0%, rgba(94, 234, 212, 0.18), transparent 55%),
                radial-gradient(900px circle at 86% 10%, rgba(56, 189, 248, 0.16), transparent 55%),
                radial-gradient(700px circle at 50% 110%, rgba(251, 113, 133, 0.10), transparent 60%),
                var(--bg);
            min-height: 100vh;
            padding: 20px;
            color: var(--text);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        
        .dashboard-container {
            max-width: 100%;
            margin: 0 auto;
        }
        
        .header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            padding: 25px 30px;
            margin-bottom: 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid rgba(255, 255, 255, 0.18);
        }
        
        .header-left {
            flex: 1;
        }
        
        .header h1 {
            color: #2d3748;
            font-size: 28px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
        }
        
        .header-info {
            color: #718096;
            font-size: 14px;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }
        
        .header-info span {
            display: flex;
            align-items: center;
            gap: 5px;
        }
        
        .status-indicator {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #48bb78;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .controls {
            display: flex;
            gap: 12px;
            align-items: center;
        }
        
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
            color: white;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }
        
        .btn-secondary {
            background: #e2e8f0;
            color: #4a5568;
        }
        
        .btn-secondary:hover {
            background: #cbd5e0;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }
        
        .stat-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.18);
            transition: transform 0.3s ease;
        }
        
        .stat-card:hover {
            transform: translateY(-5px);
        }
        
        .stat-card h3 {
            color: #718096;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 10px;
        }
        
        .stat-card .value {
            color: #2d3748;
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 5px;
        }
        
        .stat-card .change {
            font-size: 12px;
            color: #48bb78;
        }
        
        .charts-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }
        
        .chart-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }
        
        .chart-card h3 {
            color: #2d3748;
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .filter-section {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }
        
        .filter-section h3 {
            color: #2d3748;
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 15px;
        }
        
        .filter-row {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            align-items: center;
        }
        
        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }
        
        .filter-group label {
            font-size: 12px;
            font-weight: 600;
            color: #718096;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .filter-group select,
        .filter-group input {
            padding: 10px 15px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-size: 14px;
            background: white;
            color: #2d3748;
            transition: border-color 0.3s ease;
            min-width: 150px;
        }
        
        .filter-group select:focus,
        .filter-group input:focus {
            outline: none;
            border-color: #1e3a8a;
        }
        
        .table-section {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }
        
        .table-section h3 {
            color: #2d3748;
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 20px;
        }
        
        .table-scroll-container {
            position: relative;
        }
        
        .table-scrollbar-top {
            width: 100%;
            height: 20px;
            overflow-x: scroll; /* 항상 스크롤바 표시 */
            overflow-y: hidden;
            margin-bottom: 10px;
            border-radius: 8px;
            background: #f8f9fa;
            display: block;
        }
        
        .table-scrollbar-top::-webkit-scrollbar {
            height: 12px;
        }
        
        .table-scrollbar-top::-webkit-scrollbar-track {
            background: #e9ecef;
            border-radius: 6px;
        }
        
        .table-scrollbar-top::-webkit-scrollbar-thumb {
            background: #1e3a8a;
            border-radius: 6px;
            border: 2px solid #e9ecef;
        }
        
        .table-scrollbar-top::-webkit-scrollbar-thumb:hover {
            background: #3b82f6;
            cursor: pointer;
        }
        
        .table-scrollbar-top-content {
            height: 1px;
            min-width: 100%;
        }
        
        .table-wrapper {
            overflow-x: auto;
            border-radius: 8px;
        }
        
        .table-wrapper::-webkit-scrollbar {
            display: none; /* 아래쪽 스크롤 바 숨김 */
        }
        
        .table-wrapper {
            -ms-overflow-style: none; /* IE and Edge */
            scrollbar-width: none; /* Firefox */
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 2000px;
            font-size: 13px;
            background: white;
        }
        
        thead {
            background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
            color: white;
            position: sticky;
            top: 0;
            z-index: 10;
        }
        
        th {
            padding: 15px 12px;
            text-align: left;
            font-weight: 600;
            white-space: nowrap;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        tbody tr {
            border-bottom: 1px solid #e2e8f0;
            transition: background-color 0.2s ease;
        }
        
        tbody tr:nth-child(even) {
            background-color: #f7fafc;
        }
        
        tbody tr:hover {
            background-color: #edf2f7;
        }
        
        tbody tr.error-row {
            cursor: pointer;
        }
        
        tbody tr.error-row:hover {
            background-color: #fed7d7;
            box-shadow: 0 2px 4px rgba(245, 101, 101, 0.2);
        }
        
        td {
            padding: 12px;
            border-right: 1px solid #e2e8f0;
            white-space: nowrap;
        }
        
        .status-success {
            color: #48bb78;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        
        .status-success::before {
            content: '●';
            font-size: 8px;
        }
        
        .status-error {
            color: #f56565;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        
        .status-error::before {
            content: '●';
            font-size: 8px;
        }
        
        .status-warning {
            color: #ed8936;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        
        .status-warning::before {
            content: '●';
            font-size: 8px;
        }
        
        .check-ok {
            color: #48bb78;
            font-size: 18px;
            font-weight: bold;
        }
        
        .check-fail {
            color: #f56565;
            font-size: 18px;
            font-weight: bold;
        }
        
        /* 카드 그리드 레이아웃 */
        .results-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
            gap: 20px;
        }
        
        .result-card {
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            padding: 24px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }
        
        .result-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #1e3a8a, #3b82f6);
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .result-card:hover::before {
            opacity: 1;
        }
        
        .result-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.15);
            border-color: #cbd5e0;
        }
        
        .result-card.error-card {
            border-color: #fc8181;
            background: linear-gradient(135deg, #fff5f5 0%, #ffffff 50%);
        }
        
        .result-card.error-card::before {
            background: linear-gradient(90deg, #dc2626, #ef4444);
        }
        
        .result-card.error-card:hover {
            box-shadow: 0 16px 40px rgba(239, 68, 68, 0.25);
        }
        
        .result-card.success-card {
            border-color: #9ae6b4;
            background: linear-gradient(135deg, #f0fff4 0%, #ffffff 50%);
        }
        
        .result-card.success-card::before {
            background: linear-gradient(90deg, #059669, #10b981);
        }
        
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
            padding-bottom: 16px;
            border-bottom: 2px solid #f1f5f9;
        }
        
        .card-title {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        
        .card-type-badge {
            font-size: 10px;
            font-weight: 800;
            padding: 6px 14px;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: inline-block;
            width: fit-content;
        }
        
        .card-hostname {
            font-size: 18px;
            font-weight: 700;
            color: #1e293b;
            letter-spacing: -0.02em;
        }
        
        .card-status {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 700;
            padding: 8px 16px;
            border-radius: 24px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .card-status::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            animation: statusPulse 2s infinite;
        }
        
        @keyframes statusPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.7; }
        }
        
        .card-status.status-success {
            background: #d1fae5;
            color: #065f46;
        }
        
        .card-status.status-success::before {
            background: #10b981;
        }
        
        .card-status.status-error {
            background: #fee2e2;
            color: #991b1b;
        }
        
        .card-status.status-error::before {
            background: #ef4444;
            animation: statusPulseError 1s infinite;
        }
        
        @keyframes statusPulseError {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.4); opacity: 0.6; }
        }
        
        .card-status.status-warning {
            background: #fef3c7;
            color: #92400e;
        }
        
        .card-status.status-warning::before {
            background: #f59e0b;
        }
        
        .card-body {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin-bottom: 16px;
        }
        
        .card-field {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        
        .card-field-label {
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }
        
        .card-field-value {
            font-size: 14px;
            font-weight: 600;
            color: #1e293b;
            word-break: break-word;
        }
        
        .card-field-value.path {
            font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Fira Code', 'Courier New', monospace;
            font-size: 11px;
            color: #475569;
            background: #f8fafc;
            padding: 8px 10px;
            border-radius: 8px;
            font-weight: 500;
            border: 1px solid #e2e8f0;
        }
        
        .card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 16px;
            border-top: 1px solid #f1f5f9;
            font-size: 11px;
            color: #64748b;
        }
        
        .card-time, .card-checker {
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .card-time::before {
            content: '🕐';
            font-size: 14px;
        }
        
        .card-checker {
            font-weight: 600;
            color: #475569;
        }
        
        .card-checker::before {
            content: '👤';
            font-size: 14px;
        }
        
        /* 뷰 전환 버튼 */
        .view-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }
        
        .view-toggle {
            display: flex;
            gap: 8px;
            background: #f1f5f9;
            padding: 4px;
            border-radius: 12px;
        }
        
        .view-btn {
            padding: 10px 20px;
            border: none;
            background: transparent;
            border-radius: 10px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 700;
            color: #64748b;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .view-btn:hover {
            color: #334155;
        }
        
        .view-btn.active {
            background: white;
            color: #1e3a8a;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }
        
        .results-info {
            font-size: 14px;
            color: #64748b;
            font-weight: 600;
        }
        
        .results-info strong {
            color: #1e293b;
        }
        
        .loading {
            text-align: center;
            padding: 60px;
            color: #718096;
            font-size: 16px;
        }
        
        .loading::after {
            content: '...';
            animation: dots 1.5s steps(4, end) infinite;
        }
        
        @keyframes dots {
            0%, 20% { content: '.'; }
            40% { content: '..'; }
            60%, 100% { content: '...'; }
        }
        
        .no-data {
            text-align: center;
            padding: 60px;
            color: #a0aec0;
            font-size: 16px;
        }
        
        .badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .badge-mariadb {
            background: #e6fffa;
            color: #234e52;
        }
        
        .badge-postgresql {
            background: #ebf8ff;
            color: #2c5282;
        }
        
        .badge-cubrid {
            background: #fef5e7;
            color: #744210;
        }
        
        /* 모달 스타일 */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            z-index: 1000;
            backdrop-filter: blur(4px);
        }
        
        .modal-overlay.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .modal-content {
            background: white;
            border-radius: 12px;
            padding: 30px;
            max-width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            position: relative;
            animation: modalSlideIn 0.3s ease;
        }
        
        @keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid #e2e8f0;
        }
        
        .modal-header h2 {
            color: #2d3748;
            font-size: 24px;
            margin: 0;
        }
        
        .modal-close {
            background: none;
            border: none;
            font-size: 28px;
            color: #a0aec0;
            cursor: pointer;
            padding: 0;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            transition: all 0.2s;
        }
        
        .modal-close:hover {
            background: #edf2f7;
            color: #2d3748;
        }
        
        .modal-body {
            color: #4a5568;
        }
        
        .detail-section {
            margin-bottom: 25px;
        }
        
        .detail-section h3 {
            color: #2d3748;
            font-size: 18px;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid #e2e8f0;
        }
        
        .detail-item {
            margin-bottom: 12px;
            padding: 12px;
            background: #f7fafc;
            border-radius: 6px;
            border-left: 3px solid #1e3a8a;
        }
        
        .detail-item-label {
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 6px;
            font-size: 14px;
        }
        
        .detail-item-value {
            color: #4a5568;
            font-size: 14px;
            word-break: break-word;
            white-space: pre-wrap;
            font-family: 'Courier New', monospace;
            background: white;
            padding: 8px;
            border-radius: 4px;
            max-height: 200px;
            overflow-y: auto;
        }
        
        .error-highlight {
            background: #fed7d7;
            border-left-color: #f56565;
        }
        
        .success-highlight {
            background: #c6f6d5;
            border-left-color: #48bb78;
        }

        /* ==========================
           NeoGlass Dark overrides
           - 기존 기능/레이아웃 유지
           ========================== */
        .header,
        .stat-card,
        .chart-card,
        .filter-section,
        .table-section {
            background: var(--panel) !important;
            border: 1px solid var(--border) !important;
            box-shadow: var(--shadow) !important;
            border-radius: var(--radius) !important;
            backdrop-filter: blur(var(--glass-blur)) !important;
        }

        .header h1 {
            color: var(--text) !important;
            letter-spacing: -0.02em;
        }

        .header-info,
        .filter-group label {
            color: var(--muted) !important;
        }

        .status-indicator {
            background: var(--success) !important;
            animation: none !important;
            box-shadow: 0 0 0 3px rgba(52, 211, 153, 0.16);
        }

        .btn {
            border-radius: 10px !important;
            border: 1px solid var(--border) !important;
            box-shadow: none !important;
        }

        .btn-primary {
            background: var(--primary) !important;
            color: rgba(2, 6, 23, 0.92) !important;
        }

        .btn-primary:hover {
            transform: none !important;
            box-shadow: none !important;
            background: #2dd4bf !important;
        }

        .btn-secondary {
            background: rgba(2, 6, 23, 0.30) !important;
            color: rgba(255, 255, 255, 0.92) !important;
        }

        .btn-secondary:hover {
            background: rgba(2, 6, 23, 0.45) !important;
        }

        /* 카드 다크 테마 */
        .result-card {
            background: var(--panel) !important;
            border-color: var(--border) !important;
            box-shadow: var(--shadow-sm) !important;
            backdrop-filter: blur(var(--glass-blur)) !important;
        }

        .result-card:hover {
            border-color: rgba(94, 234, 212, 0.45) !important;
            box-shadow: var(--shadow) !important;
        }

        .result-card.error-card {
            border-color: rgba(251, 113, 133, 0.55) !important;
            background: rgba(251, 113, 133, 0.08) !important;
        }

        .result-card.success-card {
            border-color: rgba(52, 211, 153, 0.55) !important;
            background: rgba(52, 211, 153, 0.08) !important;
        }

        .card-header {
            border-bottom-color: var(--border) !important;
        }

        .card-hostname,
        .card-field-value {
            color: var(--text) !important;
        }

        .card-field-label {
            color: var(--muted) !important;
        }

        .card-field-value.path {
            background: rgba(2, 6, 23, 0.35) !important;
            border-color: var(--border) !important;
            color: rgba(226, 232, 240, 0.86) !important;
        }

        .card-footer {
            border-top-color: var(--border) !important;
            color: var(--muted) !important;
        }

        .card-checker {
            color: rgba(226, 232, 240, 0.92) !important;
        }

        .card-status.status-success {
            background: rgba(52, 211, 153, 0.18) !important;
            color: rgba(209, 250, 229, 0.95) !important;
        }

        .card-status.status-error {
            background: rgba(251, 113, 133, 0.18) !important;
            color: rgba(254, 226, 226, 0.95) !important;
        }

        .card-status.status-warning {
            background: rgba(251, 191, 36, 0.18) !important;
            color: rgba(254, 243, 199, 0.95) !important;
        }

        /* 뷰 토글 다크 테마 */
        .view-toggle {
            background: rgba(2, 6, 23, 0.35) !important;
        }

        .view-btn {
            color: var(--muted) !important;
        }

        .view-btn.active {
            background: rgba(94, 234, 212, 0.18) !important;
            color: var(--primary) !important;
            box-shadow: 0 0 0 1px rgba(94, 234, 212, 0.35) !important;
        }

        .results-info {
            color: var(--muted) !important;
        }

        .results-info strong {
            color: var(--text) !important;
        }

        .table-section h3 {
            color: var(--text) !important;
        }

        thead {
            background: var(--table-head) !important;
        }

        th {
            text-transform: none !important;
            letter-spacing: 0 !important;
            font-size: 12px;
        }

        /* Table + modal dark tuning */
        table {
            background: transparent !important;
        }

        tbody tr {
            border-bottom: 1px solid var(--border) !important;
        }

        tbody tr:nth-child(even) {
            background-color: rgba(2, 6, 23, 0.18) !important;
        }

        tbody tr:hover {
            background-color: rgba(94, 234, 212, 0.08) !important;
        }

        tbody tr.error-row:hover {
            background-color: rgba(251, 113, 133, 0.12) !important;
            box-shadow: none !important;
        }

        td {
            border-right: 1px solid var(--border) !important;
            color: rgba(226, 232, 240, 0.92);
        }

        .table-scrollbar-top {
            background: rgba(2, 6, 23, 0.22) !important;
            border: 1px solid var(--border);
        }

        .table-scrollbar-top::-webkit-scrollbar-track {
            background: rgba(2, 6, 23, 0.18);
        }

        .table-scrollbar-top::-webkit-scrollbar-thumb {
            background: rgba(94, 234, 212, 0.55);
            border: 2px solid rgba(2, 6, 23, 0.18);
        }

        .table-scrollbar-top::-webkit-scrollbar-thumb:hover {
            background: rgba(56, 189, 248, 0.70);
        }

        .modal-content {
            background: rgba(17, 25, 40, 0.92) !important;
            border: 1px solid rgba(148, 163, 184, 0.22) !important;
            color: rgba(226, 232, 240, 0.92) !important;
            backdrop-filter: blur(var(--glass-blur)) !important;
        }

        .modal-header {
            border-bottom: 1px solid var(--border) !important;
        }

        .modal-header h2,
        .detail-section h3,
        .detail-item-label {
            color: rgba(255, 255, 255, 0.92) !important;
        }

        .detail-item {
            background: rgba(2, 6, 23, 0.35) !important;
            border-left-color: rgba(94, 234, 212, 0.60) !important;
        }

        .detail-item-value {
            background: rgba(2, 6, 23, 0.28) !important;
            border: 1px solid var(--border) !important;
            color: rgba(226, 232, 240, 0.92) !important;
        }

        .modal-close:hover {
            background: rgba(2, 6, 23, 0.35) !important;
            color: rgba(255, 255, 255, 0.92) !important;
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <div class="header">
            <div class="header-left">
                <h1>DB 점검 결과 모니터링 대시보드</h1>
                <div class="header-info" id="headerInfo">
                    <span><span class="status-indicator"></span> 실시간 모니터링</span>
                    <span>총 0건</span>
                    <span>최신순 정렬</span>
                    <span>업데이트: -</span>
                </div>
            </div>
            <div class="controls">
                <button class="btn btn-primary" onclick="loadData()">새로고침</button>
            </div>
        </div>
        
        <div class="stats-grid" id="statsGrid">
            <div class="stat-card">
                <h3>전체 점검</h3>
                <div class="value" id="statTotal">0</div>
                <div class="change">모든 DB 유형</div>
            </div>
            <div class="stat-card">
                <h3>MariaDB</h3>
                <div class="value" id="statMariaDB">0</div>
                <div class="change" id="statMariaDBChange">-</div>
            </div>
            <div class="stat-card">
                <h3>PostgreSQL</h3>
                <div class="value" id="statPostgreSQL">0</div>
                <div class="change" id="statPostgreSQLChange">-</div>
            </div>
            <div class="stat-card">
                <h3>CUBRID</h3>
                <div class="value" id="statCUBRID">0</div>
                <div class="change" id="statCUBRIDChange">-</div>
            </div>
        </div>
        
        <div class="charts-section">
            <div class="chart-card">
                <h3>점검 유형별 분포</h3>
                <canvas id="typeChart"></canvas>
            </div>
            <div class="chart-card">
                <h3>상태별 분포</h3>
                <canvas id="statusChart"></canvas>
            </div>
            <div class="chart-card">
                <h3>일별 점검 추이</h3>
                <canvas id="trendChart"></canvas>
            </div>
        </div>
        
        <div class="filter-section">
            <h3>필터</h3>
            <div class="filter-row">
                <div class="filter-group">
                    <label>점검 유형</label>
                    <select id="filterType" onchange="applyFilters()">
                        <option value="">전체</option>
                        <option value="MARIADB">MariaDB</option>
                        <option value="POSTGRESQL">PostgreSQL</option>
                        <option value="CUBRID">CUBRID</option>
                    </select>
                </div>
                
                <div class="filter-group">
                    <label>호스트명</label>
                    <input type="text" id="filterHostname" placeholder="호스트명 검색" onkeyup="applyFilters()">
                </div>
                
                <div class="filter-group">
                    <label>담당자</label>
                    <input type="text" id="filterChecker" placeholder="담당자 검색" onkeyup="applyFilters()">
                </div>
                
                <div class="filter-group">
                    <label>상태</label>
                    <select id="filterStatus" onchange="applyFilters()">
                        <option value="">전체</option>
                        <option value="success">성공</option>
                        <option value="warning">경고</option>
                        <option value="error">오류</option>
                    </select>
                </div>
                
                <div class="filter-group">
                    <label>&nbsp;</label>
                    <button class="btn btn-secondary" onclick="clearFilters()">필터 초기화</button>
                </div>
            </div>
        </div>
        
        <div class="table-section">
            <div class="view-controls">
                <h3>상세 점검 결과</h3>
                <div style="display: flex; align-items: center; gap: 20px;">
                    <div class="results-info" id="resultsInfo">
                        총 <strong>0</strong>건
                    </div>
                    <div class="view-toggle">
                        <button class="view-btn active" onclick="switchView('card')" id="cardViewBtn">
                            <span>📇</span> 카드 뷰
                        </button>
                        <button class="view-btn" onclick="switchView('table')" id="tableViewBtn">
                            <span>📊</span> 테이블 뷰
                        </button>
                    </div>
                </div>
            </div>
            
            <!-- 카드 그리드 뷰 -->
            <div class="results-grid" id="resultsGrid">
                <div class="loading">데이터 로딩 중</div>
            </div>
            
            <!-- 테이블 뷰 -->
            <div class="table-scroll-container" id="tableScrollContainer" style="display: none;">
                <div class="table-scrollbar-top" id="topScrollbar">
                    <div class="table-scrollbar-top-content" id="topScrollbarContent"></div>
                </div>
                <div class="table-wrapper" id="tableWrapper">
                    <div class="loading">데이터 로딩 중</div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- 오류 상세 정보 모달 -->
    <div class="modal-overlay" id="errorModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>점검 상세 정보</h2>
                <button class="modal-close" onclick="closeErrorModal()">&times;</button>
            </div>
            <div class="modal-body" id="modalBody">
                <!-- 상세 정보가 여기에 표시됩니다 -->
            </div>
        </div>
    </div>
    
    <script>
        let currentZoom = 100;
        let ws = null;
        let allData = [];
        let typeChart = null;
        let statusChart = null;
        let trendChart = null;
        let lastPostedStatsKey = '';

        function computeStatusCounts(data) {
            const success = data.filter(r => String(r.상태 || '').toLowerCase().includes('success') && !String(r.상태 || '').toLowerCase().includes('x')).length;
            const warning = data.filter(r => String(r.상태 || '').toLowerCase().includes('warning')).length;
            const error = data.filter(r => String(r.상태 || '').toLowerCase().includes('error') || String(r.상태 || '').toLowerCase().includes('success x')).length;
            return { success, warning, critical: error, total: data.length };
        }

        function postStatsToParent(stats) {
            try {
                if (!window.parent || window.parent === window) return;
                const payload = { type: 'report_stats', source: 'db', ...stats };
                const key = JSON.stringify(payload);
                if (key === lastPostedStatsKey) return;
                lastPostedStatsKey = key;
                window.parent.postMessage(payload, window.location.origin);
            } catch (e) {}
        }
        
        // 차트 초기화
        function initCharts() {
            // Dark theme defaults
            Chart.defaults.color = 'rgba(226, 232, 240, 0.86)';
            Chart.defaults.borderColor = 'rgba(148, 163, 184, 0.18)';

            const typeCtx = document.getElementById('typeChart').getContext('2d');
            typeChart = new Chart(typeCtx, {
                type: 'doughnut',
                data: {
                    labels: ['MariaDB', 'PostgreSQL', 'CUBRID'],
                    datasets: [{
                        data: [0, 0, 0],
                        backgroundColor: ['#38b2ac', '#4299e1', '#ed8936'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
            
            const statusCtx = document.getElementById('statusChart').getContext('2d');
            statusChart = new Chart(statusCtx, {
                type: 'bar',
                data: {
                    labels: ['성공', '경고', '오류'],
                    datasets: [{
                        label: '점검 상태',
                        data: [0, 0, 0],
                        backgroundColor: ['#48bb78', '#ed8936', '#f56565'],
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
            
            const trendCtx = document.getElementById('trendChart').getContext('2d');
            trendChart = new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [{
                        label: '점검 수',
                        data: [],
                        borderColor: '#1e3a8a',
                        backgroundColor: 'rgba(102, 126, 234, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
        }
        
        // 데이터 로드
        let originalDataMap = new Map(); // ID를 키로 하는 원본 데이터 맵
        
        async function loadData() {
            try {
                // 포맷된 데이터 가져오기 (테이블 표시용)
                const response = await fetch('/api/db-checks/data?limit=1000');
                const data = await response.json();
                
                if (data.success && data.results) {
                    allData = data.results;
                    console.log(`✅ DB 점검 데이터 로드 완료: ${allData.length}개`);
                    
                    // 원본 데이터도 함께 가져오기 (상세 정보 표시용)
                    try {
                        const originalResponse = await fetch('/api/checks?limit=1000');
                        const originalData = await originalResponse.json();
                        if (originalData.success && originalData.results) {
                            originalDataMap.clear();
                            originalData.results.forEach(item => {
                                originalDataMap.set(item.id, item);
                            });
                            console.log(`✅ 원본 데이터 로드 완료: ${originalDataMap.size}개`);
                        }
                    } catch (err) {
                        console.warn('원본 데이터 로드 실패 (상세 정보는 포맷된 데이터로 표시됩니다):', err);
                    }
                    
                    applyFilters();
                    updateStats(allData);
                    updateCharts(allData);
                } else {
                    console.error('❌ 데이터 로드 실패:', data);
                    const errorMsg = '<div class="no-data">데이터를 불러올 수 없습니다.</div>';
                    document.getElementById('resultsGrid').innerHTML = errorMsg;
                    document.getElementById('tableWrapper').innerHTML = errorMsg;
                }
            } catch (error) {
                console.error('❌ 데이터 로딩 중 오류:', error);
                const errorMsg = '<div class="no-data">데이터 로딩 중 오류가 발생했습니다: ' + error.message + '</div>';
                document.getElementById('resultsGrid').innerHTML = errorMsg;
                document.getElementById('tableWrapper').innerHTML = errorMsg;
            }
        }
        
        // 필터 적용
        function applyFilters() {
            const filterType = document.getElementById('filterType').value;
            const filterHostname = document.getElementById('filterHostname').value.toLowerCase();
            const filterChecker = document.getElementById('filterChecker').value.toLowerCase();
            const filterStatus = document.getElementById('filterStatus').value.toLowerCase();
            
            let filtered = allData.filter(row => {
                // 점검 유형 필터 (대소문자 구분 없이)
                if (filterType) {
                    const rowType = String(row.점검유형 || '').toUpperCase();
                    if (rowType !== filterType.toUpperCase()) {
                        return false;
                    }
                }
                
                // 호스트명 필터
                if (filterHostname) {
                    const hostname = String(row.호스트명 || '').toLowerCase();
                    if (!hostname.includes(filterHostname)) {
                        return false;
                    }
                }
                
                // 담당자 필터
                if (filterChecker) {
                    const checker = String(row.담당자 || '').toLowerCase();
                    if (!checker.includes(filterChecker)) {
                        return false;
                    }
                }
                
                // 상태 필터
                if (filterStatus) {
                    const status = String(row.상태 || '').toLowerCase();
                    if (!status.includes(filterStatus)) {
                        return false;
                    }
                }
                
                return true;
            });
            
            currentFilteredData = filtered;
            
            // 현재 뷰 모드에 따라 렌더링
            if (currentView === 'card') {
                renderCards(filtered);
            } else {
                renderTable(filtered);
            }
            
            updateHeaderInfo(filtered.length);
            updateStats(filtered);
            updateCharts(filtered);
        }
        
        // 필터 초기화
        function clearFilters() {
            document.getElementById('filterType').value = '';
            document.getElementById('filterHostname').value = '';
            document.getElementById('filterChecker').value = '';
            document.getElementById('filterStatus').value = '';
            applyFilters();
        }
        
        // 통계 업데이트
        function updateStats(data) {
            const total = data.length;
            const mariadb = data.filter(r => String(r.점검유형 || '').toUpperCase() === 'MARIADB').length;
            const postgresql = data.filter(r => String(r.점검유형 || '').toUpperCase() === 'POSTGRESQL').length;
            const cubrid = data.filter(r => String(r.점검유형 || '').toUpperCase() === 'CUBRID').length;
            
            document.getElementById('statTotal').textContent = total;
            document.getElementById('statMariaDB').textContent = mariadb;
            document.getElementById('statPostgreSQL').textContent = postgresql;
            document.getElementById('statCUBRID').textContent = cubrid;

            // 통합 리포트(iframe) 상단 배지 갱신용
            postStatsToParent(computeStatusCounts(data));
        }
        
        // 차트 업데이트
        function updateCharts(data) {
            // 점검 유형별 분포
            const mariadb = data.filter(r => String(r.점검유형 || '').toUpperCase() === 'MARIADB').length;
            const postgresql = data.filter(r => String(r.점검유형 || '').toUpperCase() === 'POSTGRESQL').length;
            const cubrid = data.filter(r => String(r.점검유형 || '').toUpperCase() === 'CUBRID').length;
            
            typeChart.data.datasets[0].data = [mariadb, postgresql, cubrid];
            typeChart.update();
            
            // 상태별 분포
            const success = data.filter(r => String(r.상태 || '').toLowerCase().includes('success') && !String(r.상태 || '').toLowerCase().includes('x')).length;
            const warning = data.filter(r => String(r.상태 || '').toLowerCase().includes('warning')).length;
            const error = data.filter(r => String(r.상태 || '').toLowerCase().includes('error') || String(r.상태 || '').toLowerCase().includes('success x')).length;
            
            statusChart.data.datasets[0].data = [success, warning, error];
            statusChart.update();
            
            // 일별 추이
            const dateMap = {};
            data.forEach(row => {
                // 원본 날짜 우선 사용 (차트용), 없으면 포맷된 날짜 시도
                const checkTime = row.check_time || row.점검시간;
                if (checkTime) {
                    try {
                        let date;
                        // ISO 8601 형식인 경우 (원본 날짜)
                        if (typeof checkTime === 'string' && (checkTime.includes('T') || checkTime.includes('Z'))) {
                            date = new Date(checkTime);
                        } else {
                            // 포맷된 날짜인 경우 파싱 시도
                            date = new Date(checkTime);
                        }
                        
                        if (!isNaN(date.getTime())) {
                            const dateStr = date.toLocaleDateString('ko-KR', { 
                                year: 'numeric',
                                month: '2-digit', 
                                day: '2-digit' 
                            });
                            dateMap[dateStr] = (dateMap[dateStr] || 0) + 1;
                        }
                    } catch (e) {
                        console.error('Date parsing error:', e, checkTime);
                    }
                }
            });
            
            // 데이터가 없거나 1건일 때 최근 7일 표시
            let dates = Object.keys(dateMap).sort();
            let counts = dates.map(d => dateMap[d]);
            
            if (dates.length === 0 || dates.length === 1) {
                const today = new Date();
                dates = [];
                counts = [];
                for (let i = 6; i >= 0; i--) {
                    const d = new Date(today);
                    d.setDate(d.getDate() - i);
                    const dateStr = d.toLocaleDateString('ko-KR', { 
                        year: 'numeric',
                        month: '2-digit', 
                        day: '2-digit' 
                    });
                    dates.push(dateStr);
                    counts.push(dateMap[dateStr] || 0);
                }
            }
            
            trendChart.data.labels = dates;
            trendChart.data.datasets[0].data = counts;
            trendChart.update('none'); // 애니메이션 없이 업데이트
        }
        
        // 헤더 정보 업데이트
        function updateHeaderInfo(count) {
            const now = new Date();
            const timeStr = now.toLocaleString('ko-KR', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });
            
            const infoEl = document.getElementById('headerInfo');
            infoEl.innerHTML = `
                <span><span class="status-indicator"></span> 실시간 모니터링</span>
                <span>총 ${count}건</span>
                <span>최신순 정렬</span>
                <span>업데이트: ${timeStr}</span>
            `;
        }
        
        // 컬럼 결정 (첫 행 기준이 아니라 전체 결과의 union으로 고정)
        // - 최신 결과 타입이 바뀌어도 테이블 컬럼이 흔들리지 않게 함
        // - DB 종류별로 키가 다르더라도 기존 결과가 N/A로 "바뀐 것처럼" 보이지 않게 함
        const COLUMN_PRIORITY = [
            'id',
            '점검유형',
            '호스트명',
            '점검시간',
            '담당자',
            '상태',
            '설치확인',
            '설치경로',
            // DB 공통으로 자주 보는 항목들
            '서비스상태',
            '리스너(MariaDB)',
            '리스너(PostgreSQL)',
            'DB엔진파일시스템',
            '아카이브로그파일시스템',
            '시스템로그파일시스템',
            '파일시스템',
            '디렉토리구조',
            '메모리(Total)',
            '메모리(Used)',
            '메모리(Available)',
            'CPU사용률',
            '프로세스수',
            '데이터베이스수',
            '데이터베이스목록',
            '테이블스페이스',
        ];

        // N/A를 오류로 판단할 때는 "필수 컬럼"만 본다
        // (DB 종류가 섞인 테이블에서 타입별 비해당 컬럼은 N/A가 정상임)
        const CRITICAL_COLUMNS_FOR_NA = ['id', '점검유형', '호스트명', '점검시간', '담당자', '상태'];

        function getUnifiedColumns(results) {
            const colSet = new Set();
            results.forEach(row => {
                if (row && typeof row === 'object') {
                    Object.keys(row).forEach(k => colSet.add(k));
                }
            });

            const cols = Array.from(colSet);
            const priorityIndex = new Map(COLUMN_PRIORITY.map((c, i) => [c, i]));
            cols.sort((a, b) => {
                const ai = priorityIndex.has(a) ? priorityIndex.get(a) : 100000;
                const bi = priorityIndex.has(b) ? priorityIndex.get(b) : 100000;
                if (ai !== bi) return ai - bi;
                // 나머지는 한글/영문 섞여 있어도 안정적으로 정렬
                return String(a).localeCompare(String(b), 'ko');
            });
            return cols;
        }

        // 현재 뷰 모드
        let currentView = 'card'; // 'card' or 'table'
        
        // 뷰 전환 함수
        function switchView(view) {
            currentView = view;
            const cardViewBtn = document.getElementById('cardViewBtn');
            const tableViewBtn = document.getElementById('tableViewBtn');
            const resultsGrid = document.getElementById('resultsGrid');
            const tableScrollContainer = document.getElementById('tableScrollContainer');
            
            if (view === 'card') {
                cardViewBtn.classList.add('active');
                tableViewBtn.classList.remove('active');
                resultsGrid.style.display = 'grid';
                tableScrollContainer.style.display = 'none';
            } else {
                cardViewBtn.classList.remove('active');
                tableViewBtn.classList.add('active');
                resultsGrid.style.display = 'none';
                tableScrollContainer.style.display = 'block';
            }
            
            // 현재 데이터로 재렌더링
            if (allData.length > 0) {
                if (view === 'card') {
                    renderCards(allData);
                } else {
                    renderTable(allData);
                }
            }
        }
        
        // 카드 렌더링
        function renderCards(results) {
            console.log(`📇 카드 렌더링 시작: ${results.length}개 결과`);
            const resultsGrid = document.getElementById('resultsGrid');
            const resultsInfo = document.getElementById('resultsInfo');
            
            if (results.length === 0) {
                resultsGrid.innerHTML = '<div class="no-data">표시할 데이터가 없습니다.</div>';
                resultsInfo.innerHTML = '총 <strong>0</strong>건';
                return;
            }
            
            resultsInfo.innerHTML = `총 <strong>${results.length}</strong>건`;
            
            let html = '';
            results.forEach((row, index) => {
                const status = String(row.상태 || '').toLowerCase();
                const hasNA = CRITICAL_COLUMNS_FOR_NA.some(col => {
                    const value = row[col];
                    return value === null || value === undefined || value === 'N/A' || value === '';
                });
                const isError = status.includes('error') || status.includes('x') || hasNA;
                const isSuccess = status.includes('success') && !status.includes('x');
                
                const cardClass = isError ? 'error-card' : (isSuccess ? 'success-card' : '');
                const statusClass = isError ? 'status-error' : (isSuccess ? 'status-success' : 'status-warning');
                const statusText = isError ? 'Error' : (isSuccess ? 'Success' : 'Warning');
                
                const dbType = String(row.점검유형 || 'N/A').toUpperCase();
                const badgeClass = dbType === 'MARIADB' ? 'badge-mariadb' : 
                                  (dbType === 'POSTGRESQL' ? 'badge-postgresql' : 'badge-cubrid');
                
                const hostname = row.호스트명 || 'N/A';
                const checker = row.담당자 || 'N/A';
                const checkTime = formatDateTime(row.점검시간);
                const installPath = row.설치경로 || row.conf경로 || 'N/A';
                const servicePath = row.설정경로 || row.서비스경로 || 'N/A';
                const serviceStatus = row.서비스상태 || 'N/A';
                const listening = row['리스닝(MariaDB)'] || row.리스닝 || 'N/A';
                
                html += `
                    <div class="result-card ${cardClass}" onclick="showErrorDetails(${index})">
                        <div class="card-header">
                            <div class="card-title">
                                <span class="badge card-type-badge ${badgeClass}">${dbType}</span>
                                <div class="card-hostname">${hostname}</div>
                            </div>
                            <div class="card-status ${statusClass}">${statusText}</div>
                        </div>
                        <div class="card-body">
                            <div class="card-field">
                                <div class="card-field-label">서비스 상태</div>
                                <div class="card-field-value">${serviceStatus}</div>
                            </div>
                            <div class="card-field">
                                <div class="card-field-label">리스닝</div>
                                <div class="card-field-value">${listening}</div>
                            </div>
                            <div class="card-field" style="grid-column: 1 / -1;">
                                <div class="card-field-label">설치 경로</div>
                                <div class="card-field-value path">${installPath}</div>
                            </div>
                            <div class="card-field" style="grid-column: 1 / -1;">
                                <div class="card-field-label">설정 경로</div>
                                <div class="card-field-value path">${servicePath}</div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <div class="card-time">${checkTime}</div>
                            <div class="card-checker">${checker}</div>
                        </div>
                    </div>
                `;
            });
            
            resultsGrid.innerHTML = html;
        }
        
        // 날짜 포맷팅 헬퍼
        function formatDateTime(value) {
            if (!value) return 'N/A';
            try {
                const date = new Date(value);
                if (!isNaN(date.getTime())) {
                    return date.toLocaleString('ko-KR', {
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                }
            } catch (e) {
                return String(value);
            }
            return String(value);
        }
        
        // 테이블 렌더링
        function renderTable(results) {
            console.log(`📊 테이블 렌더링 시작: ${results.length}개 결과`);
            const resultsInfo = document.getElementById('resultsInfo');
            
            if (results.length === 0) {
                console.warn('⚠️ 렌더링할 데이터가 없습니다');
                document.getElementById('tableWrapper').innerHTML = 
                    '<div class="no-data">표시할 데이터가 없습니다.</div>';
                document.getElementById('topScrollbarContent').style.width = '0px';
                resultsInfo.innerHTML = '총 <strong>0</strong>건';
                return;
            }
            
            resultsInfo.innerHTML = `총 <strong>${results.length}</strong>건`;
            
            const columns = getUnifiedColumns(results);
            
            let html = '<table><thead><tr>';
            columns.forEach(col => {
                html += `<th>${col}</th>`;
            });
            html += '</tr></thead><tbody>';
            
            results.forEach((row, index) => {
                const status = String(row.상태 || '').toLowerCase();
                // 오류 판단: error, x 포함, 또는 (필수 컬럼에서) N/A 값이 있는 경우
                const hasNA = CRITICAL_COLUMNS_FOR_NA.some(col => {
                    const value = row[col];
                    return value === null || value === undefined || value === 'N/A' || value === '';
                });
                const isError = status.includes('error') || status.includes('x') || hasNA;
                const rowClass = isError ? 'error-row' : '';
                const rowId = `row-${index}`;
                
                // 모든 행을 클릭 가능하도록 수정 (커서 스타일 추가)
                html += `<tr class="${rowClass}" style="cursor: pointer;" onclick="showErrorDetails(${index})" data-row-index="${index}">`;
                columns.forEach(col => {
                    html += `<td>${formatCell(row[col], col)}</td>`;
                });
                html += '</tr>';
            });
            
            html += '</tbody></table>';
            document.getElementById('tableWrapper').innerHTML = html;
            
            // 스크롤 바 동기화 설정
            syncScrollbars();
        }
        
        // 스크롤 바 동기화 함수 (이벤트 리스너 중복 방지)
        let scrollbarSyncInitialized = false;
        function syncScrollbars() {
            const tableWrapper = document.getElementById('tableWrapper');
            const topScrollbar = document.getElementById('topScrollbar');
            const topScrollbarContent = document.getElementById('topScrollbarContent');
            
            if (!tableWrapper || !topScrollbar || !topScrollbarContent) return;
            
            // 테이블이 렌더링될 때까지 약간의 지연
            setTimeout(() => {
                const table = tableWrapper.querySelector('table');
                if (table) {
                    const tableWidth = table.offsetWidth;
                    const wrapperWidth = tableWrapper.clientWidth;
                    
                    // 스크롤바는 항상 표시하되, 핸들이 확실히 보이도록 최소 1px 오버플로우 보장
                    topScrollbar.style.display = 'block';
                    topScrollbarContent.style.width = Math.max(tableWidth, wrapperWidth + 1) + 'px';
                    
                    // 이벤트 리스너는 한 번만 추가
                    if (!scrollbarSyncInitialized) {
                        // 기존 리스너 제거 후 새로 추가 (중복 방지)
                        const scrollHandler = function() {
                            topScrollbar.scrollLeft = tableWrapper.scrollLeft;
                        };
                        const scrollbarHandler = function() {
                            tableWrapper.scrollLeft = topScrollbar.scrollLeft;
                        };
                        
                        tableWrapper.removeEventListener('scroll', scrollHandler);
                        topScrollbar.removeEventListener('scroll', scrollbarHandler);
                        
                        tableWrapper.addEventListener('scroll', scrollHandler);
                        topScrollbar.addEventListener('scroll', scrollbarHandler);
                        scrollbarSyncInitialized = true;
                    }
                } else {
                    // 테이블이 없으면 스크롤바 숨김
                    topScrollbarContent.style.width = '0px';
                    topScrollbar.style.display = 'none';
                }
            }, 150);
        }
        
        // 셀 포맷팅
        function formatCell(value, columnName) {
            if (value === null || value === undefined || value === 'N/A' || value === '') {
                return '<span style="color: #a0aec0;">N/A</span>';
            }
            
            // 점검유형 배지
            if (columnName === '점검유형') {
                const type = String(value).toUpperCase();
                let badgeClass = '';
                if (type === 'MARIADB') badgeClass = 'badge-mariadb';
                else if (type === 'POSTGRESQL') badgeClass = 'badge-postgresql';
                else if (type === 'CUBRID') badgeClass = 'badge-cubrid';
                return `<span class="badge ${badgeClass}">${value}</span>`;
            }
            
            // 상태 컬럼
            if (columnName === '상태') {
                const status = String(value).toLowerCase();
                if (status.includes('success') && !status.includes('x')) {
                    return `<span class="status-success">${value}</span>`;
                } else if (status.includes('error') || status.includes('x')) {
                    return `<span class="status-error">${value}</span>`;
                } else if (status.includes('warning')) {
                    return `<span class="status-warning">${value}</span>`;
                }
            }
            
            // 설치확인 컬럼
            if (columnName === '설치확인') {
                if (value === '✓' || value === true || String(value).toLowerCase() === 'true') {
                    return '<span class="check-ok">✓</span>';
                } else {
                    return '<span class="check-fail">✗</span>';
                }
            }
            
            // 날짜/시간 포맷팅 (T가 포함되어 있거나 날짜 객체로 변환 가능한 경우)
            if (columnName === '점검시간') {
                try {
                    const date = new Date(value);
                    if (!isNaN(date.getTime())) {
                        return date.toLocaleString('ko-KR');
                    }
                } catch (e) {
                    return String(value);
                }
            }
            
            return String(value);
        }
        
        // WebSocket 연결
        function connectWebSocket() {
            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const wsUrl = `${protocol}//${window.location.host}/ws`;
            
            ws = new WebSocket(wsUrl);
            
            ws.onopen = () => {
                console.log('WebSocket connected');
                setInterval(() => {
                    if (ws.readyState === WebSocket.OPEN) {
                        ws.send('ping');
                    }
                }, 30000);
            };
            
            ws.onmessage = (event) => {
                const data = JSON.parse(event.data);
                if (data.type === 'new_check_result') {
                    loadData();
                }
            };
            
            ws.onerror = (error) => {
                console.error('WebSocket error:', error);
            };
            
            ws.onclose = () => {
                setTimeout(connectWebSocket, 5000);
            };
        }
        
        // 상세 정보 표시 (모든 행 클릭 가능)
        let currentFilteredData = [];
        
        function showErrorDetails(index) {
            const rowData = currentFilteredData[index];
            if (!rowData) return;
            
            const modal = document.getElementById('errorModal');
            const modalBody = document.getElementById('modalBody');
            
            // 원본 데이터 가져오기 (맵에서 찾기)
            let originalData = originalDataMap.get(rowData.id);
            
            // 맵에 없으면 API에서 직접 가져오기
            if (!originalData) {
                fetch(`/api/checks?id=${rowData.id}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.success && data.results && data.results.length > 0) {
                            originalData = data.results[0];
                            originalDataMap.set(originalData.id, originalData);
                            displayErrorDetails(originalData);
                        } else {
                            // 포맷된 데이터로 표시 (원본 데이터가 없는 경우)
                            displayErrorDetails(rowData);
                        }
                    })
                    .catch(err => {
                        console.error('Error fetching original data:', err);
                        // 포맷된 데이터로 표시
                        displayErrorDetails(rowData);
                    });
            } else {
                displayErrorDetails(originalData);
            }
        }
        
        function displayErrorDetails(data) {
            const modalBody = document.getElementById('modalBody');
            // 원본 데이터인지 포맷된 데이터인지 확인
            const isOriginalData = data.results && typeof data.results === 'object' && !Array.isArray(data.results);
            const results = isOriginalData ? data.results : {};
            const checkType = data.check_type || data.점검유형 || 'UNKNOWN';
            
            let html = '';
            
            // 기본 정보
            html += '<div class="detail-section">';
            html += '<h3>기본 정보</h3>';
            html += `<div class="detail-item"><div class="detail-item-label">점검 유형</div><div class="detail-item-value">${checkType.toUpperCase()}</div></div>`;
            html += `<div class="detail-item"><div class="detail-item-label">호스트명</div><div class="detail-item-value">${data.hostname || data.호스트명 || 'N/A'}</div></div>`;
            html += `<div class="detail-item"><div class="detail-item-label">점검 시간</div><div class="detail-item-value">${data.check_time || data.점검시간 || 'N/A'}</div></div>`;
            html += `<div class="detail-item"><div class="detail-item-label">담당자</div><div class="detail-item-value">${data.checker || data.담당자 || 'N/A'}</div></div>`;
            html += `<div class="detail-item ${data.status && data.status.toLowerCase().includes('error') ? 'error-highlight' : 'success-highlight'}"><div class="detail-item-label">상태</div><div class="detail-item-value">${data.status || 'N/A'}</div></div>`;
            html += '</div>';
            
            // 점검 결과 상세 (원본 데이터가 있는 경우만)
            if (isOriginalData && Object.keys(results).length > 0) {
                html += '<div class="detail-section">';
                html += '<h3>점검 결과 상세</h3>';
                
                // results 객체의 모든 항목 표시
                for (const [key, value] of Object.entries(results)) {
                    let displayValue = '';
                    let isError = false;
                    
                    // N/A 값도 표시하되 오류로 강조
                    if (value === null || value === undefined || value === 'N/A' || value === '') {
                        displayValue = 'N/A (값 없음)';
                        isError = true;
                    } else if (typeof value === 'object') {
                        displayValue = JSON.stringify(value, null, 2);
                        // 에러 메시지나 실패 상태 확인
                        if (JSON.stringify(value).toLowerCase().includes('error') || 
                            JSON.stringify(value).toLowerCase().includes('fail')) {
                            isError = true;
                        }
                    } else {
                        displayValue = String(value);
                        if (displayValue.toLowerCase().includes('error') || 
                            displayValue.toLowerCase().includes('fail') ||
                            displayValue === 'N/A') {
                            isError = true;
                        }
                    }
                    
                    const itemClass = isError ? 'error-highlight' : '';
                    html += `<div class="detail-item ${itemClass}">`;
                    html += `<div class="detail-item-label">${key}</div>`;
                    html += `<div class="detail-item-value" style="white-space: pre-wrap; word-break: break-word; max-height: 200px; overflow-y: auto;">${escapeHtml(displayValue)}</div>`;
                    html += '</div>';
                }
                
                html += '</div>';
            } else {
                // 포맷된 데이터인 경우 테이블의 모든 컬럼 표시
                html += '<div class="detail-section">';
                html += '<h3>점검 결과 상세</h3>';
                
                for (const [key, value] of Object.entries(data)) {
                    // 기본 정보는 이미 표시했으므로 제외
                    if (['id', '점검유형', '호스트명', '점검시간', '담당자', '상태', 'check_type', 'hostname', 'check_time', 'checker', 'status'].includes(key)) {
                        continue;
                    }
                    
                    let displayValue = '';
                    let isError = false;
                    
                    if (value === null || value === undefined || value === 'N/A' || value === '') {
                        displayValue = 'N/A (값 없음)';
                        isError = true;
                    } else if (typeof value === 'object') {
                        displayValue = JSON.stringify(value, null, 2);
                    } else {
                        displayValue = String(value);
                        if (displayValue.toLowerCase().includes('error') || 
                            displayValue.toLowerCase().includes('fail') ||
                            displayValue === 'N/A') {
                            isError = true;
                        }
                    }
                    
                    const itemClass = isError ? 'error-highlight' : '';
                    html += `<div class="detail-item ${itemClass}">`;
                    html += `<div class="detail-item-label">${key}</div>`;
                    html += `<div class="detail-item-value" style="white-space: pre-wrap; word-break: break-word; max-height: 200px; overflow-y: auto;">${escapeHtml(displayValue)}</div>`;
                    html += '</div>';
                }
                
                html += '</div>';
            }
            
            // 원본 데이터 (디버깅용)
            html += '<div class="detail-section">';
            html += '<h3>📄 원본 데이터 (JSON)</h3>';
            html += `<div class="detail-item"><div class="detail-item-value" style="max-height: 300px; overflow-y: auto; white-space: pre-wrap; font-family: monospace; font-size: 12px;">${escapeHtml(JSON.stringify(data, null, 2))}</div></div>`;
            html += '</div>';
            
            modalBody.innerHTML = html;
            document.getElementById('errorModal').classList.add('active');
        }
        
        function closeErrorModal() {
            document.getElementById('errorModal').classList.remove('active');
        }
        
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        // 모달 외부 클릭 시 닫기
        document.addEventListener('click', (e) => {
            const modal = document.getElementById('errorModal');
            if (e.target === modal) {
                closeErrorModal();
            }
        });
        
        // ESC 키로 모달 닫기
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeErrorModal();
            }
        });
        
        // 초기화
        document.addEventListener('DOMContentLoaded', () => {
            initCharts();
            loadData();
            connectWebSocket();
            setInterval(loadData, 30000);
        });
    </script>
</body>
</html>
