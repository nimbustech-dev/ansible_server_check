# DB (선택: 없으면 SQLite 사용)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# 최초 관리자 계정 (서버 기동 시 해당 사용자가 없으면 자동 생성)
# 반드시 설정 후 첫 기동 시 관리자로 로그인하여 다른 사용자를 승인할 수 있습니다.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT 서명용 시크릿 (프로덕션에서는 반드시 변경)
# JWT_SECRET_KEY=your-secret-key

# 서버 SSH 비밀번호 암호화 (관리자에서 비밀번호로 등록 시 필수)
# ENCRYPTION_KEY= 또는 ANSIBLE_SERVER_ENCRYPTION_KEY= 32자 이상 문자열 또는 Fernet base64url 키

# 동적 inventory API 키 (Cron/run_checks_from_api.sh용, 노출 금지)
# INVENTORY_API_KEY=long-random-secret
